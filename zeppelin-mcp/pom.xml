<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <artifactId>zeppelin</artifactId>
    <groupId>org.apache.zeppelin</groupId>
    <version>0.13.0-SNAPSHOT</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <artifactId>zeppelin-mcp</artifactId>
  <packaging>pom</packaging>
  <name>Zeppelin: MCP Server</name>
  <description>Model Context Protocol server for operating Zeppelin notebooks from AI agents</description>

  <properties>
    <!-- The Python interpreter used to build the venv and run tests. -->
    <python.executable>python3</python.executable>
    <!-- Set -Dpython.test.skip=true to skip the pytest run (e.g. when Python is unavailable). -->
    <python.test.skip>false</python.test.skip>
    <mcp.venv.dir>${project.build.directory}/venv</mcp.venv.dir>
  </properties>

  <build>
    <plugins>
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <executions>
          <!-- Create an isolated virtualenv and install the package + test deps. -->
          <execution>
            <id>mcp-venv-setup</id>
            <phase>test-compile</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <skip>${python.test.skip}</skip>
              <executable>${python.executable}</executable>
              <workingDirectory>${project.basedir}</workingDirectory>
              <arguments>
                <argument>-m</argument>
                <argument>venv</argument>
                <argument>${mcp.venv.dir}</argument>
              </arguments>
            </configuration>
          </execution>
          <execution>
            <id>mcp-pip-install</id>
            <phase>test-compile</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <skip>${python.test.skip}</skip>
              <executable>${mcp.venv.dir}/bin/pip</executable>
              <workingDirectory>${project.basedir}</workingDirectory>
              <arguments>
                <argument>install</argument>
                <argument>--quiet</argument>
                <argument>.[test]</argument>
              </arguments>
            </configuration>
          </execution>
          <!-- Run the pytest suite during the test phase. -->
          <execution>
            <id>mcp-pytest</id>
            <phase>test</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <skip>${python.test.skip}</skip>
              <executable>${mcp.venv.dir}/bin/pytest</executable>
              <workingDirectory>${project.basedir}</workingDirectory>
              <arguments>
                <argument>-q</argument>
              </arguments>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <!-- `mvn test -DskipTests` should also skip the Python tests. -->
    <profile>
      <id>skip-python-tests</id>
      <activation>
        <property>
          <name>skipTests</name>
        </property>
      </activation>
      <properties>
        <python.test.skip>true</python.test.skip>
      </properties>
    </profile>
  </profiles>
</project>
